# Evolution API config for LOCAL DEV (npm run dev + this stack only).
#
#   cp .env.example .env      # then `docker compose up -d` in this folder
#
# The whole-stack root docker-compose.yml does NOT use this file — it
# inlines the same config and reads the gateway key from the root .env.
# This file is only for running Evolution on its own while you run the
# app with `npm run dev`.

# --- Server ---
SERVER_TYPE=http
SERVER_PORT=8080
# API reachable from the host at :8088 (mapped to the container's 8080).
SERVER_URL=http://localhost:8088

# Global gateway key — the app must send this SAME value as EVOLUTION_API_KEY.
# CHANGE THIS. Generate one:
#   node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
AUTHENTICATION_API_KEY=change-me-evolution-global-key
AUTHENTICATION_EXPOSE_IN_FETCH_INSTANCES=true

TELEMETRY_ENABLED=false
LOG_LEVEL=ERROR,WARN,INFO,LOG
LOG_COLOR=true
LOG_BAILEYS=error
DEL_INSTANCE=false

# --- Database (the evolution-postgres service) ---
DATABASE_PROVIDER=postgresql
DATABASE_CONNECTION_URI=postgresql://evolution:evolution@evolution-postgres:5432/evolution?schema=public
DATABASE_CONNECTION_CLIENT_NAME=evolution_exchange
DATABASE_SAVE_DATA_INSTANCE=true
DATABASE_SAVE_DATA_NEW_MESSAGE=true
DATABASE_SAVE_MESSAGE_UPDATE=true
DATABASE_SAVE_DATA_CONTACTS=true
DATABASE_SAVE_DATA_CHATS=true

# Postgres container credentials (consumed by docker-compose.yaml)
POSTGRES_DATABASE=evolution
POSTGRES_USERNAME=evolution
POSTGRES_PASSWORD=evolution

# --- Cache (the evolution-redis service) ---
CACHE_REDIS_ENABLED=true
CACHE_REDIS_URI=redis://evolution-redis:6379/6
CACHE_REDIS_TTL=604800
CACHE_REDIS_PREFIX_KEY=evolution
CACHE_REDIS_SAVE_INSTANCES=false
CACHE_LOCAL_ENABLED=false

# --- WhatsApp session identity (the linked-device name shown on the phone) ---
CONFIG_SESSION_PHONE_CLIENT=wacrm-free
CONFIG_SESSION_PHONE_NAME=Chrome
QRCODE_LIMIT=30

# CORS
CORS_ORIGIN=*
CORS_METHODS=GET,POST,PUT,DELETE
CORS_CREDENTIALS=true
